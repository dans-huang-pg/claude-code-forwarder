{
  "manifest_version": 3,
  "name": "Claude Code Forwarder",
  "version": "1.2.0",
  "description": "Cmd+Shift+F to forward Gmail/Slack threads to Claude Code",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://app.slack.com/*",
    "http://localhost:5581/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*", "https://app.slack.com/*"],
      "js": ["shortcut-listener.js"],
      "run_at": "document_idle"
    }
  ],
"icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
